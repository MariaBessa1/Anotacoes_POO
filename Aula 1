#region condicionais 

//Tradicional

if (idade >= 18)
    Console.WriteLine("Maior de idade");
else
    Console.WriteLine("Menor de idade");

//Outra forma

Console.WriteLine(idade >= 18 
    ? "Pessoa é maior de idade"
    : "Pessoa é menor de idade");

Console.WriteLine(idade > 18
    ? "Pessoa é maior de idade"
    : idade == 18 ? "Idade igual a 18"
    : "Pessoa é menor de idade");

#endregion

#region laços de repetição

//Tradicional

var i = 0;
while(i < 7)
{
    Console.WriteLine(i);
    i++;
}

for (i = 0; i < 7; i++) 
    Console.WriteLine(i);

//Outra forma

foreach(var numero in Enumerable.Range(0,7))
    Console.WriteLine(numero);

#endregion

