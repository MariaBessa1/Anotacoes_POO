#region tipos primitivos / variáveis

short idade = 18; //short é valor usado para numeros pequenos, forma de economizar memória. Short é o unico que o c# não faz a conversão automatica do var.
var numeroVirgula = 18.6; //Var pode ser usada p qualquer um, o c# entende e ja faz a conversão automatica. Porém o ideal é deixar explicito o tipo.
long visualizacoesYoutube = 5_300_230_123_345_294; //Long é usado para valores enormes


